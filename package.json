{
  "name": "asana-shooter",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker that forwards Asana task payloads to a downstream webhook when the 'Assessment System' custom field is set to 'New System'.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "register-webhook": "node scripts/register-webhook.mjs",
    "list-webhooks": "node scripts/list-webhooks.mjs",
    "delete-webhook": "node scripts/delete-webhook.mjs",
    "test-callback": "node scripts/test-callback.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
